    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Go Program",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/lohar",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": true,
            "dlvToolPath": "/home/hs/go/bin/dlv",
            "useApiV1": true,
            "env": {
                "LOHAR_TEST": "1",
                "LOHAR_SOCK": "/tmp/lohar-control.sock",
                "LOHAR_FWD_SOCK": "/tmp/lohar-forward.sock"
            },
            "args": []
        }        
    ]
}